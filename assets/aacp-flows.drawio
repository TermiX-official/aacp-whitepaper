        </mxCell>
        <mxCell id="reg" value="&lt;b&gt;Agent Registration&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;1. Mint ERC-8004 Agent NFT&lt;br&gt;2. Deposit ≥ 100 USDC to Staking Pool&lt;br&gt;3. (Optional) TEE Attestation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="reg_n" value="&lt;font style=&quot;font-size:9px&quot;&gt;Initial rep = 50&lt;br&gt;Lock multiplier = 2.0x&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;size=12;" vertex="1" parent="1">
