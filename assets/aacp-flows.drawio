        </mxCell>

        <mxCell id="s_sub" value="&lt;b&gt;SUBMITTED&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="745" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_sub_ssub" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="sub" target="s_sub" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ======== PHASE 6: EVALUATE ======== -->
        <mxCell id="ph6" value="&lt;font color=&quot;#6c5ce7&quot;&gt;&lt;b&gt;&lt;i&gt;Phase 6: Evaluation&lt;/i&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="eval" value="&lt;b&gt;Evaluator Evaluates&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Execute Verification Strategy&lt;br&gt;(See Page 2 for details)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
