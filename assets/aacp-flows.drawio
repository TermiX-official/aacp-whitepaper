        <!-- Slashing table -->
        <mxCell id="stitle" value="&lt;b&gt;9 Evaluator Slashing Violations&lt;/b&gt;" style="text;html=1;align=left;fontSize=10;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="600" y="800" width="300" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="stable" value="&lt;font style=&quot;font-size:8px&quot;&gt;&lt;table cellpadding=&quot;3&quot; border=&quot;1&quot; style=&quot;border-collapse:collapse;border-color:#b85450&quot;&gt;&lt;tr style=&quot;background:#f8cecc&quot;&gt;&lt;td&gt;&lt;b&gt;Violation&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;1st&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;3+&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Rep&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Timeout (48h)&lt;/td&gt;&lt;td&gt;30%&lt;/td&gt;&lt;td&gt;50%&lt;/td&gt;&lt;td&gt;-5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Overturned&lt;/td&gt;&lt;td&gt;60%&lt;/td&gt;&lt;td&gt;100%&lt;/td&gt;&lt;td&gt;-15&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Borderline manipulation&lt;/td&gt;&lt;td&gt;80%&lt;/td&gt;&lt;td&gt;100%&lt;/td&gt;&lt;td&gt;-20&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Statistical anomaly&lt;/td&gt;&lt;td&gt;40%&lt;/td&gt;&lt;td&gt;80%&lt;/td&gt;&lt;td&gt;-10&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Selective submission&lt;/td&gt;&lt;td&gt;70%&lt;/td&gt;&lt;td&gt;100%&lt;/td&gt;&lt;td&gt;-15&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Human panel outlier&lt;/td&gt;&lt;td&gt;20%&lt;/td&gt;&lt;td&gt;50%&lt;/td&gt;&lt;td&gt;-5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Panel collusion&lt;/td&gt;&lt;td&gt;100%+ban&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;=0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Collusion w/ Provider&lt;/td&gt;&lt;td&gt;100%+ban&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;=0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Collusion w/ Client&lt;/td&gt;&lt;td&gt;100%+ban&lt;/td&gt;&lt;td&gt;—&lt;/td&gt;&lt;td&gt;=0&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#b85450;arcSize=6;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="600" y="825" width="320" height="230" as="geometry"/>
        </mxCell>

        <!-- Slash distribution -->
        <mxCell id="sdist" value="&lt;b&gt;Slash Distribution&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;60% → Victim&lt;br&gt;30% → Treasury&lt;br&gt;10% → Arbitrators&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="960" y="870" width="150" height="65" as="geometry"/>
        </mxCell>

        <!-- Cost scaling -->
        <mxCell id="cst" value="&lt;b&gt;Dispute Cost Scaling&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• Evaluator overturned recently → ×0.5&lt;br&gt;• program (zkVM) → budget×2%&lt;br&gt;• human consensus → budget×4%&lt;br&gt;• Score near threshold → ×0.5&lt;br&gt;• Floor: 5 USDC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;arcSize=8;align=left;" vertex="1" parent="1">
          <mxGeometry x="600" y="1080" width="240" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="arr34" value="↓ After penalization → recovery path" style="text;html=1;align=center;fontColor=#999;fontSize=10;" vertex="1" parent="1">
