          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- T+48h -->
        <mxCell id="d_t48l" value="&lt;b&gt;T+48h&lt;/b&gt;" style="text;html=1;align=right;fontSize=11;fontColor=#6c5ce7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="480" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="d_t48" value="&lt;b&gt;Evidence Phase&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;All parties submit evidence (IPFS, hashes on-chain)&lt;br&gt;Deliverable + Verification Strategy available to arbitrators&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="130" y="470" width="350" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_t0_t48" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="d_t0" target="d_t48" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- T+96h -->
        <mxCell id="d_t96l" value="&lt;b&gt;T+96h&lt;/b&gt;" style="text;html=1;align=right;fontSize=11;fontColor=#6c5ce7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="565" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="d_t96" value="&lt;b&gt;Independent Re-Evaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Each arbitrator re-evaluates using &lt;b&gt;same verification strategy&lt;/b&gt;:&lt;br&gt;• program → re-run in zkVM&lt;br&gt;• rubric (multi-llm) → re-run in TEE&lt;br&gt;• rubric (human) → arbitrators score independently&lt;br&gt;Sealed vote (commit-reveal)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="130" y="545" width="350" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="e_t48_t96" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="d_t48" target="d_t96" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- T+120h -->
        <mxCell id="d_t120l" value="&lt;b&gt;T+120h&lt;/b&gt;" style="text;html=1;align=right;fontSize=11;fontColor=#6c5ce7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="675" width="65" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="d_t120" value="&lt;b&gt;Reveal Phase&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Arbitrators reveal votes · 2/3 majority determines outcome&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="130" y="665" width="350" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_t96_t120" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="d_t96" target="d_t120" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arbitrator incentives (right side) -->
        <mxCell id="d_arbi" value="&lt;b&gt;Arbitrator Incentives (Schelling Point)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;table cellpadding=&quot;3&quot;&gt;&lt;tr&gt;&lt;td&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;With majority&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Against&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Reward&lt;/td&gt;&lt;td&gt;deposit×10%÷3&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Reputation&lt;/td&gt;&lt;td&gt;+1&lt;/td&gt;&lt;td&gt;-2&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;Honest = most likely to agree with&lt;br&gt;other honest arbitrators&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#6c8ebf;arcSize=8;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="250" height="150" as="geometry"/>
        </mxCell>

        <!-- Outcome decision -->
        <mxCell id="d_outq" value="&lt;b&gt;Upheld?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="265" y="750" width="80" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="e_t120_outq" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="d_t120" target="d_outq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
