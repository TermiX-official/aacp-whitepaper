        <mxCell id="tn" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;⚠ Timeout&lt;/b&gt;&lt;br&gt;No submission → slash 50%/100%&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;size=12;" vertex="1" parent="1">
