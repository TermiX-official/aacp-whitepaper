          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="guilt" value="&lt;b&gt;Penalized&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Slashed per table →&lt;br&gt;Rep impact applied&lt;br&gt;Victim compensated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;" vertex="1" parent="1">
