        <mxCell id="e_eval_dq" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="eval" target="dq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- COMPLETE (right) -->
        <mxCell id="comp" value="&lt;b&gt;complete()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="670" y="1020" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq_comp" value="Yes" style="rounded=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;strokeColor=#82b366;fontColor=#82b366;endArrow=block;endFill=1;" edge="1" source="dq" target="comp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="s_comp" value="&lt;b&gt;COMPLETED&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="1080" width="120" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_comp_scomp" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="comp" target="s_comp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="pay" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;💰 Distribution&lt;/b&gt;&lt;br&gt;Provider 94% | Evaluator 4%&lt;br&gt;Treasury 2%&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;size=12;" vertex="1" parent="1">
