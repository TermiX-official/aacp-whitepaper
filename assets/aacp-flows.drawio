        <!-- ===== PROGRAM BRANCH (left) ===== -->
        <mxCell id="v_prog" value="&lt;b&gt;program&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Deterministic&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6c5ce7;fontColor=#fff;strokeColor=none;arcSize=15;shadow=1;" vertex="1" parent="1">
