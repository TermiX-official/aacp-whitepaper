        <mxCell id="sub" value="&lt;b&gt;Provider: submit()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Submit deliverable on-chain&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
