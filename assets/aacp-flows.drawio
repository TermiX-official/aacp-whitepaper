        </mxCell>
        <mxCell id="e_arb_arbq" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="arb" target="arbq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Upheld → right -->
        <mxCell id="uph" value="&lt;b&gt;Decision Upheld&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Disputing party loses deposit&lt;br&gt;Evaluator: reputation +2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;" vertex="1" parent="1">
