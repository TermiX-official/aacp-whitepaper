        </mxCell>
        <mxCell id="e_rej_srej" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="rej" target="s_rej" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="rejn" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Rejection Consequences&lt;/b&gt;&lt;br&gt;Client refunded&lt;br&gt;Provider may be slashed&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;size=12;" vertex="1" parent="1">
