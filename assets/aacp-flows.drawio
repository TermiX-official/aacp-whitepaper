        <mxCell id="arr23" value="↓ Anomaly detected → trigger response" style="text;html=1;align=center;fontColor=#999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="745" width="250" height="18" as="geometry"/>
        </mxCell>

        <!-- LAYER 3: RESPONSE -->
        <mxCell id="l3" value="" style="rounded=1;fillColor=none;strokeColor=#b85450;strokeWidth=2;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="1120" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="l3t" value="&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;LAYER 3: RESPONSE&lt;/b&gt; — Penalize confirmed misbehavior&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="775" width="450" height="20" as="geometry"/>
        </mxCell>

        <!-- Two dispute paths -->
        <mxCell id="dp" value="&lt;b&gt;Party-Initiated Dispute&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Victim pays scaled deposit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="dpr" value="&lt;b&gt;Protocol-Initiated Dispute&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Treasury pays · No cost to victim&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="810" width="200" height="45" as="geometry"/>
        </mxCell>

        <!-- Arbitration -->
        <mxCell id="arb3" value="&lt;b&gt;Arbitration&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;3 Arbitrators (VRF) · Re-evaluate · 2/3 majority&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
