        </mxCell>
        <mxCell id="l4t" value="&lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;LAYER 4: RECOVERY&lt;/b&gt; — Compensate victims and allow rehabilitation&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="1355" width="500" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="r1" value="&lt;b&gt;Victim Compensation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;60% of slashed amount&lt;br&gt;Dispute deposit returned&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="1385" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="&lt;b&gt;Partial Refund&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Close dispute (diff &lt; 10):&lt;br&gt;50% deposit refund even if loses&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="1385" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="&lt;b&gt;Rehabilitation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;500 consecutive clean jobs&lt;br&gt;→ violation count resets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="1385" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="&lt;b&gt;Permanent Ban&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Collusion confirmed:&lt;br&gt;100% slash + ban + score = 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="1385" width="180" height="55" as="geometry"/>
