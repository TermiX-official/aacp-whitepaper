        <!-- T+0 -->
        <mxCell id="d_t0l" value="&lt;b&gt;T+0&lt;/b&gt;" style="text;html=1;align=right;fontSize=11;fontColor=#6c5ce7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="d_t0" value="&lt;b&gt;Dispute Filed&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;3 Arbitrators selected via VRF (rep≥90, jobs≥50, no conflicts)&lt;br&gt;Dispute deposit locked · All parties notified&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="130" y="390" width="350" height="55" as="geometry"/>
