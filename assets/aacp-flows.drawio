        </mxCell>
        <mxCell id="e_ssub_eval" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="s_sub" target="eval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="es" value="&lt;b&gt;🔒 Evaluator Stake&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;budget×10% ÷ repCoeff&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;size=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="820" width="145" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_eval_es" style="rounded=1;dashed=1;strokeColor=#9673a6;endArrow=none;" edge="1" source="eval" target="es" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="bl" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;👁 Blind Evaluation&lt;/b&gt;&lt;br&gt;Provider identity hidden&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;size=12;" vertex="1" parent="1">
          <mxGeometry x="170" y="825" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_eval_bl" style="rounded=1;dashed=1;strokeColor=#999;endArrow=none;" edge="1" source="eval" target="bl" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DECISION: Pass? -->
        <mxCell id="dq" value="&lt;b&gt;Pass?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
