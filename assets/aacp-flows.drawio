  <!-- PAGE 1: COMPLETE JOB LIFECYCLE -->
  <diagram name="1. Job Lifecycle" id="page1">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="2600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="t" value="AACP Complete Job Lifecycle" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="400" height="35" as="geometry"/>
        </mxCell>

        <!-- LEGEND -->
        <mxCell id="lg" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;🟦 Process step&lt;br&gt;🟩 State / Success&lt;br&gt;🟥 Failure / Slash&lt;br&gt;🟧 Dispute path&lt;br&gt;🟪 Staking operation&lt;br&gt;🟨 Decision point&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="950" y="20" width="150" height="120" as="geometry"/>
        </mxCell>

        <!-- ======== PHASE 0: REGISTRATION ======== -->
