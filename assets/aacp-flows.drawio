        <mxCell id="e_arb_aq" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="arb3" target="aq3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="vind" value="&lt;b&gt;Vindicated&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;No penalty · rep +2&lt;br&gt;Protocol absorbs cost&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;" vertex="1" parent="1">
