        <!-- ======== PHASE 7: DISPUTE ======== -->
        <mxCell id="ph7" value="&lt;font color=&quot;#6c5ce7&quot;&gt;&lt;b&gt;&lt;i&gt;Phase 7: Dispute Window (48h)&lt;/i&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="1155" width="260" height="20" as="geometry"/>
        </mxCell>

        <!-- Dispute diamond centered between Rejected and Completed -->
        <mxCell id="disq" value="&lt;b&gt;Dispute&lt;br&gt;filed?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="1155" width="80" height="70" as="geometry"/>
        </mxCell>
        <!-- Rejected → dispute diamond: enter from LEFT -->
        <mxCell id="e_srej_disq" style="rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" source="s_rej" target="disq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Completed → dispute diamond: enter from RIGHT -->
        <mxCell id="e_scomp_disq" style="rounded=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" source="s_comp" target="disq" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- No dispute → Final Settlement (straight down) -->
        <mxCell id="settle" value="&lt;b&gt;Final Settlement&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;All stakes unlocked&lt;br&gt;Reputation updated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;arcSize=10;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="1280" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e_disq_settle" value="No (48h elapsed)" style="rounded=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;fontColor=#82b366;endArrow=block;endFill=1;" edge="1" source="disq" target="settle" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Yes dispute → Dispute Filed (straight down) -->
        <mxCell id="disf" value="&lt;b&gt;Dispute Filed&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Deposit: dynamically scaled&lt;br&gt;OR protocol-initiated (no victim cost)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="1280" width="220" height="55" as="geometry"/>
