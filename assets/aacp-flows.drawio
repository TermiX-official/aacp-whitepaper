        <mxCell id="e_arbq_ovt" value="No" style="rounded=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;endArrow=block;endFill=1;" edge="1" source="arbq" target="ovt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
