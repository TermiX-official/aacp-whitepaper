  <!-- PAGE 4: DISPUTE RESOLUTION -->
  <diagram name="4. Dispute Resolution" id="page4">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1500" math="0" shadow="0">
      <root>
