        </mxCell>

        <mxCell id="l1a" value="&lt;b&gt;Blind Evaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Provider identity hidden.&lt;br&gt;Revealed after scoring.&lt;br&gt;&lt;b&gt;Prevents:&lt;/b&gt; targeted&lt;br&gt;harassment, favoritism&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="105" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="l1b" value="&lt;b&gt;Evaluator Rotation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Same E-P pair: max 3×/30d&lt;br&gt;Same E-C pair: max 5×/30d&lt;br&gt;&lt;b&gt;Prevents:&lt;/b&gt; relationship&lt;br&gt;collusion&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="105" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="l1c" value="&lt;b&gt;TEE Enforcement&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Rubric runs inside TEE.&lt;br&gt;MRENCLAVE proves code.&lt;br&gt;&lt;b&gt;Prevents:&lt;/b&gt; rubric&lt;br&gt;substitution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="105" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="l1d" value="&lt;b&gt;Sealed Scoring&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Human panel can't see&lt;br&gt;each other's scores.&lt;br&gt;VRF selection.&lt;br&gt;&lt;b&gt;Prevents:&lt;/b&gt; panel&lt;br&gt;coordination&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="105" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="l1e" value="&lt;b&gt;Strategy Pinning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Hash on-chain at creation.&lt;br&gt;Cannot change after&lt;br&gt;Provider starts work.&lt;br&gt;&lt;b&gt;Prevents:&lt;/b&gt; criteria&lt;br&gt;tampering&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="105" width="160" height="90" as="geometry"/>
