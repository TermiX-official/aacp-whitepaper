        <!-- ALL STAKES UNLOCKED -->
        <mxCell id="unlock" value="&lt;b&gt;All Stakes Unlocked&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Locked → Available · Ready for next job&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;arcSize=10;shadow=1;strokeWidth=2;" vertex="1" parent="1">
