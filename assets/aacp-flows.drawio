        <mxCell id="e_disq_disf" value="Yes" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#d79b00;fontColor=#d79b00;endArrow=block;endFill=1;" edge="1" source="disq" target="disf" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="s_disp" value="&lt;b&gt;DISPUTED&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="1365" width="100" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_disf_sdisp" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="disf" target="s_disp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arbitration -->
        <mxCell id="arb" value="&lt;b&gt;Arbitration&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;3 Arbitrators (VRF)&lt;br&gt;Re-evaluate using same strategy&lt;br&gt;Sealed vote → 2/3 majority&lt;br&gt;(See Page 4)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="1430" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e_sdisp_arb" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="s_disp" target="arb" parent="1">
