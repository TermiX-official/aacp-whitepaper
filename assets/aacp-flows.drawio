        </mxCell>

        <!-- REJECT (left) -->
        <mxCell id="rej" value="&lt;b&gt;reject()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="1020" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_dq_rej" value="No" style="rounded=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;strokeColor=#b85450;fontColor=#b85450;endArrow=block;endFill=1;" edge="1" source="dq" target="rej" parent="1">
