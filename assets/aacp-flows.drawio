        </mxCell>

        <mxCell id="spd" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;⚡ Speed Bonus&lt;/b&gt;&lt;br&gt;&lt;50% deadline → +2%&lt;br&gt;&lt;25% deadline → +5%&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;size=12;" vertex="1" parent="1">
