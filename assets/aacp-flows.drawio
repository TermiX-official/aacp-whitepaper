        <!-- Decision -->
        <mxCell id="aq3" value="&lt;b&gt;Fault?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
