        <mxCell id="v_hl_f" value="&lt;font style=&quot;font-size:9px&quot;&gt;LLM runs immediately&lt;br&gt;+ 3 humans in parallel (72h)&lt;br&gt;Blend: humanW × human&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;+ llmW × llm&lt;br&gt;Divergence &gt; 20 → flag&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;arcSize=8;" vertex="1" parent="1">
