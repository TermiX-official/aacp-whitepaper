        <mxCell id="e_arbq_uph" value="Yes" style="rounded=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;fontColor=#82b366;endArrow=block;endFill=1;" edge="1" source="arbq" target="uph" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Overturned → left -->
        <mxCell id="ovt" value="&lt;b&gt;Decision Overturned&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Evaluator slashed 60-100%&lt;br&gt;Injured party compensated&lt;br&gt;Dispute deposit returned&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="170" y="1650" width="190" height="65" as="geometry"/>
