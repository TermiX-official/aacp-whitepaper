        <mxCell id="e_dterm_who" style="rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;" edge="1" source="d_term" target="d_who" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Party-initiated (left) -->
        <mxCell id="d_party" value="&lt;b&gt;Party-Initiated&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Provider/Client disputes within 48h&lt;br&gt;Pays dynamically scaled deposit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="260" width="210" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e_who_party" value="Party" style="rounded=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;fontSize=9;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="d_who" target="d_party" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Protocol-initiated (right) -->
        <mxCell id="d_proto" value="&lt;b&gt;Protocol-Initiated&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Monitoring detects statistical anomaly&lt;br&gt;Treasury pays deposit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="260" width="210" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e_who_proto" value="Protocol" style="rounded=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;edgeStyle=orthogonalEdgeStyle;fontSize=9;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="d_who" target="d_proto" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Proto triggers note -->
        <mxCell id="d_trig" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Triggers:&lt;/b&gt;&lt;br&gt;• Statistical anomaly flagged&lt;br&gt;• Low-variance human panel&lt;br&gt;• Borderline score 3+ dims&lt;br&gt;• Systematic bias vs Provider&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;size=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="870" y="255" width="195" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="e_proto_trig" style="rounded=1;dashed=1;strokeColor=#999;endArrow=none;" edge="1" source="d_proto" target="d_trig" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- TIMELINE -->
        <mxCell id="d_tl" value="&lt;font color=&quot;#6c5ce7&quot;&gt;&lt;b&gt;&lt;i&gt;Arbitration Timeline&lt;/i&gt;&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="350" y="360" width="260" height="25" as="geometry"/>
