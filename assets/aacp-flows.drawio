        <mxCell id="e_ovt_sarb" style="rounded=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;edgeStyle=orthogonalEdgeStyle;endArrow=block;endFill=1;" edge="1" source="ovt" target="s_arb" parent="1">
