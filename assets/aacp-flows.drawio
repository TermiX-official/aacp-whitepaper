        <!-- ARBITRATED state -->
        <mxCell id="s_arb" value="&lt;b&gt;ARBITRATED&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=12;" vertex="1" parent="1">
